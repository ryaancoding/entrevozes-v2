# Database Configuration
# This is REQUIRED for the application to work in production
# Copy the connection string from your MySQL provider (Railway, PlanetScale, Aiven, etc.)
# Format: mysql://username:password@host:port/database_name
DATABASE_URL=mysql://user:password@localhost:3306/entrevozes

# Example connection strings for popular providers:
# Railway: mysql://user:password@containers-us-west-XXX.railway.app:6603/railway
# PlanetScale: mysql://user:password@aws.connect.psdb.cloud/database_name?sslaccept=strict
# Aiven: mysql://user:password@mysql-XXXXX.aivencloud.com:21606/database_name?ssl-mode=REQUIRED
# Neon MySQL: mysql://user:password@pg-XXXXX.neon.tech:3306/database_name
